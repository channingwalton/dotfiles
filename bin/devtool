#!/usr/bin/env bash
set -euo pipefail

# ============================================
# devtool — unified project build tool
# ============================================
# Detects project type and runs compile, lint,
# test, or all three (check).
#
# Output is suppressed on success. On failure the
# full log is written to a temp file, whose path
# is printed and whose contents are cat'd between
# --- output --- markers. Set DEVTOOL_VERBOSE=1
# to stream output live instead.
#
# Usage:
#   devtool check            # compile + lint + test
#   devtool compile          # compile only
#   devtool lint             # lint only
#   devtool test [pattern]   # test only, optional filter
#   devtool cpd [dir] [--format <lang>] [--sorted]  # find duplicate code (jscpd)
#
# A local mise config (mise.toml etc.) overrides detection:
# every command routes to `mise run <task>` (compile, lint,
# test, and commit-check for check). Otherwise check prefers a
# commitCheck.sh or justfile commit-check recipe, falling back
# to project detection.
# ============================================

# --- Project detection ---

PROJECT_TYPE=""
HAS_MISE=false
SBT_HAS_COMMIT_CHECK=false
USE_BLOOP=false
GW="gradle"
GW_TASKS=""
PM="npm"
RUBY_TEST="rake"

# A local mise config short-circuits every command to `mise run <task>`,
# overriding project detection. Only local files count (not the global
# or parent-merged config), so this fires solely in mise-managed repos.
MISE_CONFIGS=(
  mise.toml mise.local.toml
  .mise.toml .mise.local.toml
  .config/mise.toml .config/mise/config.toml
  mise/config.toml .mise/config.toml
)

detect_mise() {
  command -v mise &>/dev/null || return
  local f
  for f in "${MISE_CONFIGS[@]}"; do
    if [[ -f "$f" ]]; then HAS_MISE=true; return; fi
  done
}

detect_project() {
  detect_mise
  if [[ -f "build.sbt" ]]; then
    PROJECT_TYPE="scala"
    if [[ -d ".bloop" ]]; then USE_BLOOP=true; fi
    if grep -q "commitCheck" build.sbt 2>/dev/null; then SBT_HAS_COMMIT_CHECK=true; fi
  elif [[ -f "build.gradle.kts" || -f "build.gradle" ]]; then
    PROJECT_TYPE="kotlin"
    if [[ -f "./gradlew" ]]; then GW="./gradlew"; fi
    GW_TASKS=$($GW tasks --all --quiet 2>/dev/null || true)
  elif [[ -f "package.json" ]]; then
    PROJECT_TYPE="node"
    if [[ -f "pnpm-lock.yaml" ]]; then PM="pnpm"; fi
    if [[ -f "yarn.lock" ]]; then PM="yarn"; fi
  elif [[ -f "Gemfile" ]]; then
    PROJECT_TYPE="ruby"
    if [[ -d "spec" ]]; then RUBY_TEST="rspec"; fi
  fi
}

gradle_has_task() {
  echo "$GW_TASKS" | grep -q "^$1 " 2>/dev/null
}

# Run a command silently; on failure, point at a log file instead of
# replaying output. Honours DEVTOOL_VERBOSE=1 to stream output live.
run_quiet() {
  if [[ "${DEVTOOL_VERBOSE:-0}" == "1" ]]; then
    "$@"
    return $?
  fi
  local logfile rc
  logfile=$(mktemp -t devtool.XXXXXX)
  set +e
  "$@" >"$logfile" 2>&1
  rc=$?
  set -e
  if (( rc != 0 )); then
    echo "devtool: command failed (exit $rc)"
    echo "  log: $logfile"
    echo "--- output ---"
    cat "$logfile"
    echo "--- end output ---"
  else
    rm -f "$logfile"
  fi
  return $rc
}

# --- Actions ---

do_compile() {
  if $HAS_MISE; then run_quiet mise run compile; return $?; fi
  case "$PROJECT_TYPE" in
    scala)
      if $USE_BLOOP; then
        run_quiet bloop compile root
      else
        run_quiet sbt --warn compile
      fi
      ;;
    kotlin)
      if gradle_has_task compileKotlin; then
        run_quiet $GW --quiet compileKotlin
      else
        run_quiet $GW --quiet classes
      fi
      ;;
    node)
      if [[ -f "tsconfig.json" ]]; then
        run_quiet npx tsc --noEmit
      else
        run_quiet $PM run build
      fi
      ;;
    ruby)
      run_quiet bundle exec rubocop
      ;;
    *)
      echo "devtool: no project detected"
      return 1
      ;;
  esac
}

do_lint() {
  if $HAS_MISE; then run_quiet mise run lint; return $?; fi
  case "$PROJECT_TYPE" in
    scala)
      # No standalone linter — handled by compiler
      ;;
    kotlin)
      if gradle_has_task ktlintCheck; then
        run_quiet $GW --quiet ktlintCheck
      else
        echo "devtool: ktlintCheck not available, skipping lint"
      fi
      ;;
    node)
      run_quiet $PM run lint || true
      ;;
    ruby)
      run_quiet bundle exec rubocop
      ;;
    *)
      echo "devtool: no project detected"
      return 1
      ;;
  esac
}

do_test() {
  if $HAS_MISE; then run_quiet mise run test "$@"; return $?; fi

  local pattern="${1:-}"

  case "$PROJECT_TYPE" in
    scala)
      if $USE_BLOOP; then
        if [[ -n "$pattern" ]]; then
          run_quiet bloop test root -o "*${pattern}*"
        else
          run_quiet bloop test root
        fi
      else
        if [[ -n "$pattern" ]]; then
          run_quiet sbt --warn "testOnly *${pattern}*"
        else
          run_quiet sbt --warn test
        fi
      fi
      ;;
    kotlin)
      if [[ -n "$pattern" ]]; then
        if echo "$GW_TASKS" | grep -q "^${pattern}:test "; then
          run_quiet $GW --quiet ":${pattern}:test"
        else
          run_quiet $GW --quiet test --tests "*${pattern}*"
        fi
      else
        run_quiet $GW --quiet test
      fi
      ;;
    node)
      if [[ -n "$pattern" ]]; then
        run_quiet $PM test -- --testPathPattern="$pattern"
      else
        run_quiet $PM test
      fi
      ;;
    ruby)
      if [[ -n "$pattern" ]]; then
        if [[ "$RUBY_TEST" == "rspec" ]]; then
          run_quiet bundle exec rspec --pattern "**/*${pattern}*"
        else
          run_quiet bundle exec rake test TEST="test/**/*${pattern}*"
        fi
      else
        if [[ "$RUBY_TEST" == "rspec" ]]; then
          run_quiet bundle exec rspec
        else
          run_quiet bundle exec rake test
        fi
      fi
      ;;
    *)
      echo "devtool: no project detected"
      return 1
      ;;
  esac
}

cpd_usage() {
  echo "Usage: devtool cpd [directory] [--format <lang>] [--sorted]"
  echo "  directory:       source directory (default: .)"
  echo "  --format <lang>: restrict to one jscpd format (kotlin, ruby, typescript, …;"
  echo "                   run 'jscpd --list' for the full set). Default: all detected."
  echo "  --sorted:        list clones largest first (needs jq)"
}

do_cpd() {
  local lang=""
  local src_dir=""
  local sorted=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --sorted)  sorted=true; shift ;;
      --format)
        if [[ -z "${2:-}" ]]; then echo "devtool cpd: --format needs a language"; return 1; fi
        lang="$2"; shift 2
        ;;
      --format=*) lang="${1#*=}"; shift ;;
      -h|--help)  cpd_usage; return 0 ;;
      -*)         echo "devtool cpd: unknown option $1"; cpd_usage; return 1 ;;
      *)
        if [[ -n "$src_dir" ]]; then echo "devtool cpd: unexpected argument $1"; return 1; fi
        src_dir="$1"; shift
        ;;
    esac
  done
  src_dir="${src_dir:-.}"

  if ! command -v jscpd &>/dev/null; then
    echo "devtool: jscpd not found — install with: brew install jscpd"
    return 1
  fi

  local fmt_args=()
  if [[ -n "$lang" ]]; then fmt_args=(--format "$lang"); fi

  if ! $sorted; then
    jscpd --min-tokens 100 "${fmt_args[@]}" --reporters ai --no-tips "$src_dir"
    return $?
  fi

  if ! command -v jq &>/dev/null; then
    echo "devtool: jq not found (required by --sorted) — install with: brew install jq"
    return 1
  fi

  local out_dir
  out_dir=$(mktemp -d)
  # shellcheck disable=SC2064
  trap "rm -rf '$out_dir'" RETURN

  jscpd --min-tokens 100 "${fmt_args[@]}" --reporters json --output "$out_dir" \
    --no-tips "$src_dir" >/dev/null

  jq -r '
    .duplicates
    | sort_by(-.lines)
    | if length == 0 then "no duplicates found" else
        .[] | "\(.lines) lines, \(.tokens) tokens [\(.format)]\n  \(.firstFile.name):\(.firstFile.start)-\(.firstFile.end)\n  \(.secondFile.name):\(.secondFile.start)-\(.secondFile.end)"
      end
  ' "$out_dir/jscpd-report.json"
}

do_check() {
  # A local mise config wins outright.
  if $HAS_MISE; then
    run_quiet mise run commit-check
    return $?
  fi

  # Legacy project-specific commit check, only for explicit check requests.
  if [[ -f "commitCheck.sh" ]]; then
    run_quiet ./commitCheck.sh
    return $?
  fi

  # justfile with a commit-check recipe takes precedence
  if [[ -f "justfile" || -f "Justfile" ]] && command -v just &>/dev/null \
    && just --show commit-check &>/dev/null; then
    run_quiet just commit-check
    return $?
  fi

  # Scala with commitCheck sbt target
  if [[ "$PROJECT_TYPE" == "scala" ]] && $SBT_HAS_COMMIT_CHECK; then
    run_quiet sbt --warn commitCheck
    return $?
  fi

  do_compile && do_lint && do_test
}

# --- Main ---

usage() {
  echo "Usage: devtool <command> [args]"
  echo ""
  echo "Commands:"
  echo "  check            compile + lint + test (prefers just/mise commit-check)"
  echo "  compile          compile only"
  echo "  lint             lint only"
  echo "  test [pattern]   test only, optional filter"
  echo "  cpd [dir] [--format <lang>] [--sorted]  find duplicate code (uses jscpd)"
  echo ""
  echo "Env:"
  echo "  DEVTOOL_VERBOSE=1  stream output live (default: suppress on success)"
}

main() {
  local cmd="${1:-}"
  shift 2>/dev/null || true

  if [[ "$cmd" == "cpd" ]]; then
    echo "=== devtool $cmd ==="
    do_cpd "$@"
    echo "=== devtool $cmd: OK ==="
    return 0
  fi

  detect_project

  if [[ -z "$PROJECT_TYPE" && "$HAS_MISE" == false && "$cmd" != "check" ]]; then
    echo "devtool: no project detected"
    return 1
  fi

  if $HAS_MISE; then
    echo "=== devtool $cmd [mise] ==="
  elif [[ "$cmd" == "check" && -f "commitCheck.sh" ]]; then
    echo "=== devtool $cmd [commitCheck.sh] ==="
  elif [[ -n "$PROJECT_TYPE" ]]; then
    echo "=== devtool $cmd [$PROJECT_TYPE] ==="
  fi

  case "$cmd" in
    check)    do_check ;;
    compile)  do_compile ;;
    lint)     do_lint ;;
    test)     do_test "$@" ;;
    cpd)      do_cpd "$@" ;;
    *)        usage; return 1 ;;
  esac

  echo "=== devtool $cmd: OK ==="
}

main "$@"
