{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "agentPushNotifEnabled": true,
  "alwaysThinkingEnabled": true,
  "autoDreamEnabled": true,
  "cleanupPeriodDays": 99999,
  "disabledMcpjsonServers": [
    "claude_ai_Notion"
  ],
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "caveman@caveman": false,
    "chrome-devtools-mcp@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "codex@openai-codex": true,
    "commit-commands@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": false,
    "github@claude-plugins-official": false,
    "kotlin-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "pw-engineering@patchskills": true,
    "pyright-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "understand-anything@understand-anything": false
  },
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "repo": "JuliusBrussee/caveman",
        "source": "github"
      }
    },
    "openai-codex": {
      "source": {
        "repo": "openai/codex-plugin-cc",
        "source": "github"
      }
    },
    "patchskills": {
      "source": {
        "repo": "patchworkhealth/patchskills",
        "source": "github"
      }
    },
    "understand-anything": {
      "source": {
        "repo": "Lum1104/Understand-Anything",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "atuin hook claude-code",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "atuin hook claude-code",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "atuin hook claude-code",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/channing/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash '/Users/channing/.claude/hooks/review-route-hook.sh'",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:*)",
      "WebSearch",
      "Bash(./gradlew:*)",
      "Bash(awk:*)",
      "Bash(bash:*)",
      "Bash(bloop:*)",
      "Bash(brew:*)",
      "Bash(bundle:*)",
      "Bash(cat:*)",
      "Bash(/Users/channing/.claude/skills/chatter/chatter:*)",
      "Bash(chmod:*)",
      "Bash(cloc:*)",
      "Bash(command:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(date:*)",
      "Bash(devtool:*)",
      "Bash(diff:*)",
      "Bash(docker:*)",
      "Bash(env:*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(gitleaks:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(host:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(mdls:*)",
      "Bash(mdfind:*)",
      "Bash(mkdir:*)",
      "Bash(*/mysql@8.0/bin/mysql -h 127.0.0.1 -P 5433*)",
      "Bash(mv:*)",
      "Bash(node:*)",
      "Bash(nslookup:*)",
      "Bash(obsidian:*)",
      "Bash(pgrep:*)",
      "Bash(pnpm:*)",
      "Bash(printenv:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(readlink:*)",
      "Bash(realpath:*)",
      "Bash(rg:*)",
      "Bash(rm:*)",
      "Bash(sbt:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(timeout:*)",
      "Bash(touch:*)",
      "Bash(tree:*)",
      "Bash(uv:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(xargs:*)",
      "Bash(xxd:*)",
      "Glob(/Users/channing/.claude/**)",
      "Glob(/Users/channing/dev/**)",
      "Glob(/Users/channing/Documents/Notes/**)",
      "Read(/Users/channing/.claude/**)",
      "Read(/Users/channing/dev/**)",
      "Read(/Users/channing/Documents/Notes/**)",
      "Read(/Users/channing/dotfiles/**)",
      "Read(/tmp/**)",
      "Write(/Users/channing/dev/**)",
      "Edit(/Users/channing/dev/**)",
      "Skill(vault)",
      "mcp__context7__resolve-library-id",
      "mcp__fetch__fetch",
      "mcp__perplexity-mcp__perplexity_search_web",
      "mcp__unison"
    ],
    "ask": [
      "Bash(git push:*)"
    ],
    "defaultMode": "auto",
    "deny": [
      "mcp__claude_ai_Notion"
    ]
  },
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "bash '/Users/channing/.claude/statusline-command.sh'",
    "type": "command"
  },
  "teammateMode": "tmux",
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "voiceEnabled": true
}