{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 99999,
  "env": {
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:*)",
      "WebSearch",
      "Bash(./gradlew:*)",
      "Bash(awk:*)",
      "Bash(bash:*)",
      "Bash(bloop:*)",
      "Bash(brew:*)",
      "Bash(bundle:*)",
      "Bash(cat:*)",
      "Bash(chmod:*)",
      "Bash(cloc:*)",
      "Bash(command:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(date:*)",
      "Bash(devtool:*)",
      "Bash(diff:*)",
      "Bash(docker:*)",
      "Bash(echo:*)",
      "Bash(env:*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(gitleaks:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(host:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(mdls:*)",
      "Bash(mdfind:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(node:*)",
      "Bash(nslookup:*)",
      "Bash(obsidian:*)",
      "Bash(pgrep:*)",
      "Bash(pnpm:*)",
      "Bash(printenv:*)",
      "Bash(printf:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(readlink:*)",
      "Bash(realpath:*)",
      "Bash(rg:*)",
      "Bash(rm:*)",
      "Bash(sbt:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(timeout:*)",
      "Bash(touch:*)",
      "Bash(tree:*)",
      "Bash(uv:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(xargs:*)",
      "Bash(xxd:*)",
      "Glob(/Users/channing/.claude/**)",
      "Glob(/Users/channing/dev/**)",
      "Glob(/Users/channing/Documents/Notes/**)",
      "Read(/Users/channing/.claude/**)",
      "Read(/Users/channing/dev/**)",
      "Read(/Users/channing/Documents/Notes/**)",
      "Read(/Users/channing/dotfiles/**)",
      "Read(/tmp/**)",
      "Write(/Users/channing/dev/**)",
      "Edit(/Users/channing/dev/**)",
      "Skill(code-reviewer)",
      "Skill(vault)",
      "mcp__context7__resolve-library-id",
      "mcp__fetch__fetch",
      "mcp__perplexity-mcp__perplexity_search_web",
      "mcp__unison"
    ],
    "deny": [
      "mcp__claude_ai_Notion"
    ],
    "ask": [
      "Bash(git push:*)"
    ]
  },
  "model": "opus[1m]",
  "disabledMcpjsonServers": [
    "claude_ai_Notion"
  ],
  "hooks": {},
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "elements-of-style@superpowers-marketplace": true,
    "chrome-devtools-mcp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "voiceEnabled": true,
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "autoDreamEnabled": true,
  "teammateMode": "tmux",
  "feedbackSurveyState": {
    "lastShownTime": 1754089297581
  }
}
