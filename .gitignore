# Default: ignore everything at the repo root
/*

# ===== Top-level allowlist =====
!/.gitignore
!/.gitmodules
!/.markdownlint-cli2.yaml
!/.tool-versions
!/.tmux.conf
!/.zshrc
!/CLAUDE.md
!/LICENSE
!/README.md
!/bin/
!/git-hooks/
!/keychron/
!/misc/
!/trace.json.gz
!/zshfunctions

# ===== Dotted config trees: re-open, then curate inside =====
!/.claude/
!/.config/
!/.gemini/
!/.pi/

# --- .claude/: allow only known entries ---
/.claude/*
!/.claude/CLAUDE.md
!/.claude/README.md
!/.claude/agents/
!/.claude/commands/
!/.claude/plugins/
!/.claude/settings.json
!/.claude/skills/
!/.claude/statusline.sh

# Inside .claude/plugins/: only the two manifest files
/.claude/plugins/*
!/.claude/plugins/config.json
!/.claude/plugins/installed_plugins.json

# --- .config/: allow specific tool dirs ---
/.config/*
!/.config/atuin/
!/.config/bat/
!/.config/btop/
!/.config/configstore/
!/.config/gh/

!/.config/gh-copilot/
!/.config/ghostty/
!/.config/git/
!/.config/helix/
!/.config/ideavim/
!/.config/jj/
!/.config/kitty/
!/.config/lazydocker/
!/.config/lazygit/
!/.config/lf/
!/.config/lsd/
!/.config/nvim/
!/.config/pgcli/
!/.config/wezterm/
!/.config/wtf/
!/.config/zed/

# Inside .config/configstore/: only the github copilot manifest
/.config/configstore/*
!/.config/configstore/update-notifier-@github/

# Noise inside otherwise-allowed config dirs
/.config/pgcli/history
/.config/pgcli/log
/.config/zed/.tmp*
/.config/zed/conversations
/.config/zed/embeddings
/.config/zed/prompts
/.config/zed/stable

# --- .gemini/: only curated files ---
/.gemini/*
!/.gemini/GEMINI.md
!/.gemini/settings.json.orig
!/.gemini/trustedFolders.json

# --- .pi/: only the agent tree ---
/.pi/*
!/.pi/agent/
/.pi/agent/auth.json
/.pi/agent/sessions/

# ===== Depth-agnostic noise =====
*.lock
*.log
.DS_Store
**/lazy-lock.json
**/packer_compiled.lua
