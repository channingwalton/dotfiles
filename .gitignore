# Default: ignore everything at the repo root
/*

# ===== Top-level allowlist =====
!/.audit-ignore
!/.gitignore
!/.gitmodules
!/.markdownlint-cli2.yaml
!/.profile
!/.tmux.conf
!/.bash_profile
!/.bashrc
!/.zprofile
!/.zshrc
!/AGENTS.md
!/CLAUDE.md
!/LICENSE
!/README.md
!/bin/
!/git-hooks/
!/keychron/
!/misc/
!/zshfunctions

# ===== Dotted config trees: re-open, then curate inside =====
!/.claude/
!/.codex/
!/.config/
!/.hermes/
!/.pi/

# --- .claude/: allow only known entries ---
/.claude/*
!/.claude/CLAUDE.md
!/.claude/README.md
!/.claude/agents/
!/.claude/commands/
!/.claude/hooks/
!/.claude/plugins/
!/.claude/settings.json
!/.claude/skills/
!/.claude/statusline-command.sh

# Inside .claude/plugins/: only the two manifest files
/.claude/plugins/*
!/.claude/plugins/config.json
!/.claude/plugins/installed_plugins.json

# --- .codex/: allow durable config and user-managed content only ---
/.codex/*
!/.codex/AGENTS.md
!/.codex/config.toml
!/.codex/herdr-agent-state.sh
!/.codex/hooks.json
!/.codex/rules/
!/.codex/skills/

# Inside .codex/rules/: allow rule files
/.codex/rules/*
!/.codex/rules/**/*.rules
!/.codex/rules/**/*.md

# Inside .codex/skills/: allow user-managed skills, not bundled/runtime skills
/.codex/skills/*
!/.codex/skills/**
/.codex/skills/.system/
/.codex/skills/.system/**
/.codex/skills/codex-primary-runtime/
/.codex/skills/codex-primary-runtime/**

# --- .config/: allow specific tool dirs ---
/.config/*
!/.config/atuin/
!/.config/bat/
!/.config/btop/
!/.config/caveman/
!/.config/cmux/
!/.config/codeburn/
!/.config/configstore/
!/.config/devin/
!/.config/gh/

!/.config/gh-copilot/
!/.config/gh-txplabs/
!/.config/ghostty/
!/.config/git/
!/.config/goose/
!/.config/helix/
!/.config/herdr/
!/.config/ideavim/
!/.config/jj/
!/.config/lazydocker/
!/.config/lazygit/
!/.config/lazysql/
!/.config/leaf/
!/.config/lf/
!/.config/lsd/
!/.config/mise/
!/.config/nvim/
!/.config/opencode/
!/.config/pgcli/
!/.config/wezterm/
!/.config/wtf/
!/.config/yazi/
!/.config/zed/

# Inside .config/configstore/: only the github copilot manifest
/.config/configstore/*
!/.config/configstore/update-notifier-@github/

# Inside .config/devin/: only config and skills, not the cli install
/.config/devin/*
!/.config/devin/config.json
!/.config/devin/skills/

# Inside .config/goose/: only config and skills, not tls material
/.config/goose/*
!/.config/goose/config.yaml
!/.config/goose/skills/

# Inside .config/herdr/: only config, not sockets/logs
/.config/herdr/*
!/.config/herdr/config.toml

# Inside .config/opencode/: only opencode.json, plugins/, and skills/
/.config/opencode/*
!/.config/opencode/opencode.json
!/.config/opencode/plugins/
!/.config/opencode/skills/

# Noise inside otherwise-allowed config dirs
/.config/pgcli/history
/.config/pgcli/log
/.config/zed/.tmp*
/.config/zed/conversations
/.config/zed/embeddings
/.config/zed/prompts
/.config/zed/stable

# --- .hermes/: only curated config ---
/.hermes/*
!/.hermes/config.yaml
!/.hermes/SOUL.md

# --- .pi/: only the agent tree ---
/.pi/*
!/.pi/agent/
/.pi/agent/auth.json
/.pi/agent/sessions/

# ===== Depth-agnostic noise =====
*.lock
*.log
.DS_Store
**/lazy-lock.json
!/.config/nvim/lazy-lock.json
**/packer_compiled.lua
**/__pycache__/
*.pyc
.todos/
