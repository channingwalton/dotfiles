prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["devtool", "test"], decision="allow")
prefix_rule(pattern=["npm", "install"], decision="allow")
prefix_rule(pattern=["git", "branch"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["git", "remote"], decision="allow")
prefix_rule(pattern=["git", "push"], decision="allow")
prefix_rule(pattern=["./gradlew", ":common:compileKotlin", ":audit-service:test", ":allocate-integration:compileKotlin", ":l2p-esr-integration:compileKotlin", ":expenses:compileKotlin", ":rates:compileKotlin", ":service-plans:compileKotlin", ":compliance:compileKotlin"], decision="allow")
prefix_rule(pattern=["./gradlew", ":audit-service:test", "--tests", "com.patchwork.auditservice.integration.ApiContractTest.can create an audit event with null organisation details via sqs and read it via the API"], decision="allow")
prefix_rule(pattern=["git", "switch", "-c"], decision="allow")
prefix_rule(pattern=["./gradlew", ":rota-bridge:test"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "CI=true DEVTOOL_VERBOSE=1 devtool test MoreActionsButton"], decision="allow")
prefix_rule(pattern=["pnpm", "test:run"], decision="allow")
